DESCRIPTION
"test"

PREDICTOR
t               T   s         time	0	100000

COMPARTMENTS


STATES
incl        C   pM      conc.   cyt     1  
skip        C   pM      conc.   cyt     1  
fullIR        C   pM      conc.   cyt     1    
firstIR        C   pM      conc.   cyt     1    
secondIR        C   pM      conc.   cyt     1    


    

INPUTS


ODES

"kspli*k1*k3*c1*c2*P000-kincl*incl"
"kspli*k1*k3*P000-kskip*skip"
"P000+k1*P000+c1*P000+c1*c2*P000+k3*P000+k1*c1*P000+k3*c1*P000+k1*k3*c1*P000-(kdr1+kdr2)*fullIR"
"kspli*k3*c1*c2*P000-kdr1*firstIR"
"kspli*k1*c1*c2*P000-kdr2*secondIR"

DERIVED



sum   C   "pM"   "conc."  "incl+skip+fullIR + firstIR + secondIR"

norm_inclusion    C   "pM"   "conc."            "incl/sum"
norm_skipping    C   "pM"   "conc."             "skip/sum"
norm_full_IR    C   "pM"   "conc."             "fullIR/sum"
norm_first_IR   C   "pM"   "conc."              "firstIR/sum"
norm_second_IR   C   "pM"   "conc."              "secondIR/sum"





OBSERVABLES

inclusion           C   "au"  "conc."   0   0   "norm_inclusion"
skipping           C   "au"  "conc."   0   0   "norm_skipping"
full_IR           C   "au"  "conc."   0   0   "norm_full_IR"
first_IR           C   "au"  "conc."   0   0   "norm_first_IR"
second_IR           C   "au"  "conc."   0   0   "norm_second_IR"

ERRORS
inclusion "sd"
skipping "sd" 
full_IR "sd"  
first_IR "sd" 
second_IR "sd"

CONDITIONS
P000              "s"
init_incl         "0"
init_skip         "0"
init_fullIR         "0"
init_firstIR         "0"
init_secondIR         "0"



 

